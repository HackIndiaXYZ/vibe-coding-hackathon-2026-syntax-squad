# Supabase configuration
SUPABASE_PROJECT_ID="your-supabase-project-id"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# AI service key for question generation and assistant access
# You can use LOVABLE_API_KEY for Lovable gateway (Gemini/GPT access), OPENAI_API_KEY for direct OpenAI,
# or AI_API_KEY plus AI_API_URL for any OpenAI-compatible AI provider.
LOVABLE_API_KEY="your-lovable-api-key"
LOVABLE_MODEL="google/gemini-3-flash-preview"
OPENAI_API_KEY="your-openai-api-key"
AI_API_KEY="your-generic-ai-api-key"
AI_API_URL="https://api.openai.com/v1/chat/completions"
AI_MODEL="gpt-4o-mini"
